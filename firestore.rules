rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for incoming data
    function incoming() {
      return request.resource.data;
    }

    match /saves/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && incoming().userId == userId
        && incoming().gameState is map
        && incoming().updatedAt == request.time;
      allow update: if isOwner(userId)
        && incoming().userId == userId
        && incoming().gameState is map
        && incoming().updatedAt == request.time
        && incoming().diff(resource.data).affectedKeys().hasOnly(['gameState', 'updatedAt']);
    }

    match /leaderboard/{userId} {
      allow list: if true;
      allow get: if true;
      allow create, update: if isOwner(userId)
        && incoming().uid == userId
        && incoming().wealth is number
        && incoming().displayName is string
        && incoming().displayName.size() <= 100
        && (request.method == 'create' || incoming().diff(resource.data).affectedKeys().hasOnly(['wealth', 'displayName', 'lastUpdated']))
        && incoming().lastUpdated == request.time;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
